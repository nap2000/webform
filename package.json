{
    "name": "webform",
    "description": "A fork of Webform Smart Paper that integrates with Smap",
    "homepage": "http://www.smap.com.au",
    "version": "5.18.0",
    "license": "Apache-2.0",
    "os": [
        "darwin",
        "linux",
        "win32"
    ],
    "keywords": [
        "enketo",
        "OpenRosa",
        "ODK",
        "XForms",
        "Smap",
        "form"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/nap2000/enketo-core"
    },
    "author": {
        "name": "Neil Penman",
        "email": "neilpenman@smap.com.au",
        "url": "https://www.smap.com.au"
    },
    "contributors": [
        {}
    ],
    "files": [
        "src/",
        "config.js"
    ],
    "bugs": "https://github.com/enketo/enketo-core/issues",
    "main": "src/js/form.js",
    "scripts": {
        "compile": "rollup --config",
        "start": "http-server build -p 8005",
        "minify": "terser build/js/enketo-bundle.js --compress --mangle -o build/js/bundle.min.js",
        "test": "cross-env NODE_OPTIONS='--max-old-space-size=8192' npm run lint && npm run test:headless",
        "test:headless": "cross-env NODE_OPTIONS='--max-old-space-size=8192' karma start test/karma.conf.js",
        "test:browsers": "cross-env NODE_OPTIONS='--max-old-space-size=8192' karma start test/karma.conf.js --browsers Chrome,Firefox,Safari",
        "lint": "eslint '*.js' 'src/**/*.js'",
        "lint:fix": "eslint --fix '*.js' 'src/**/*.js'",
        "beautify": "npm run lint:fix",
        "build-docs": "rimraf docs && ./node_modules/.bin/jsdoc -c jsdoc.config.js",
        "remove-docs": "rm -R ./docs/*.html"
    },
    "devDependencies": {
        "@rollup/plugin-commonjs": "^29.0.2",
        "@rollup/plugin-json": "^6.1.0",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "cross-env": "^7.0.3",
        "docdash": "^1.2.0",
        "eslint": "^7.32.0",
        "eslint-plugin-jsdoc": "^35.0.0",
        "http-server": "^14.1.1",
        "i18next-parser": "^3.11.0",
        "jasmine-core": "^6.2.0",
        "jsdoc": "^3.6.7",
        "json-pretty": "0.0.1",
        "karma": "^6.4.4",
        "karma-chrome-launcher": "^3.1.0",
        "karma-coverage": "^2.2.1",
        "karma-firefox-launcher": "^2.1.0",
        "karma-jasmine": "^5.1.0",
        "karma-rollup-preprocessor": "^7.0.8",
        "karma-safari-launcher": "^1.0.0",
        "publish-please": "^5.5.2",
        "rimraf": "^3.0.2",
        "rollup": "^4.60.2",
        "rollup-plugin-istanbul": "^5.0.0",
        "terser": "^5.46.2"
    },
    "browser": {
        "enketo/config": "./config.js",
        "enketo/widgets": "./src/js/widgets.js",
        "enketo/translator": "./src/js/translator",
        "enketo/dialog": "./src/js/fake-dialog",
        "enketo/file-manager": "./src/js/file-manager",
        "enketo/xpath-evaluator-binding": "./src/js/xpath-evaluator-binding"
    },
    "dependencies": {
        "@zxing/library": "^0.21.3",
        "bootstrap-datepicker": "1.9.x",
        "html5sortable": "0.12.1",
        "i18next": "^19.9.2",
        "i18next-browser-languagedetector": "^4.2.0",
        "i18next-fs-backend": "^1.1.1",
        "i18next-http-backend": "^1.2.8",
        "i18next-http-middleware": "^2.1.2",
        "i18next-xhr-backend": "^3.2.x",
        "jquery": "^3.6.0",
        "jquery-touchswipe": "^1.6.19",
        "leaflet": "^1.7.1",
        "leaflet.gridlayer.googlemutant": "^0.12.1",
        "mergexml": "1.2.1",
        "node-forge": "^0.10.0",
        "signature_pad": "2.3.x"
    },
    "volta": {
        "node": "24.12.0"
    }
}
